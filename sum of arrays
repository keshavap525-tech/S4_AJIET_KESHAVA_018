public class Main {
    public static void main(String[] args) {
        int[] numbers = {10, 20, 30, 40, 50};
        int sum = 0; // Initialize sum to 0

        for (int i = 0; i < numbers.length; i++) {
            sum += numbers[i]; // Add each element to sum
        }

        System.out.println("Sum of array: " + sum);
    }
}
